# Core Bale relay settings
BALE_BOT_TOKEN=
BALE_ALLOWED_CHAT_IDS=
BALE_API_BASE_URL=https://tapi.bale.ai
BALE_POLL_TIMEOUT_SEC=20

# Mattermost delivery
MATTERMOST_MODE=webhook
MATTERMOST_WEBHOOK_URL=
# MATTERMOST_BASE_URL=
# MATTERMOST_BOT_TOKEN=
# MATTERMOST_CHANNEL_ID=

# Local runtime
SQLITE_PATH=./data/relay.db
LOG_LEVEL=info

# Optional news crawler
NEWS_ENABLED=false
