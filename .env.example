# Core Bale relay settings
BALE_BOT_TOKEN=
BALE_ALLOWED_CHAT_IDS=
BALE_ALLOWED_HASHTAGS=
BALE_STRIP_MENTIONS=
BALE_STRIP_PHRASES=
BALE_API_BASE_URL=https://tapi.bale.ai
BALE_POLL_TIMEOUT_SEC=20

# Mattermost delivery
MATTERMOST_MODE=webhook
MATTERMOST_WEBHOOK_URL=
# MATTERMOST_BASE_URL=
# MATTERMOST_BOT_TOKEN=
# MATTERMOST_CHANNEL_ID=

# Local runtime
SQLITE_PATH=./data/relay.db
LOG_LEVEL=info

# Optional news crawler
NEWS_ENABLED=false
NEWS_PROVIDER=legacy_html
# NEWS_INTERVAL=15m
# NEWS_MAX_ARTICLES_PER_CYCLE=5
# NEWS_REQUEST_TIMEOUT_SEC=30
# NEWS_FETCH_DELAY_MIN_SEC=1
# NEWS_FETCH_DELAY_MAX_SEC=5
# NEWS_USER_AGENT=NewsBot/1.0
# NEWS_SITES_JSON=
# NEWS_PROVIDER=bbc_approved

# Optional Telegram userbot (reads public channels via MTProto)
TELEGRAM_ENABLED=false
# TELEGRAM_API_ID=          # from my.telegram.org
# TELEGRAM_API_HASH=        # from my.telegram.org
# TELEGRAM_PHONE=           # +989123456789
# TELEGRAM_CHANNELS=akhbarefori,farsna,tasnimnews,IranIntl,VahidOnline
# TELEGRAM_SESSION_PATH=./data/telegram.session
# TELEGRAM_ALLOWED_HASHTAGS=
# TELEGRAM_STRIP_MENTIONS=
# TELEGRAM_STRIP_PHRASES=
